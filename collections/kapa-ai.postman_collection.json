            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"How do I get started?\",\n  \"integration_id\": \"{{integrationId}}\",\n  \"context\": \"Additional grounding context.\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": []
        }
      ]
